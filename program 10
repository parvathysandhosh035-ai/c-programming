#include <stdio.h>
int main() 
{
    float a, b;
    char op;
    scanf("%f %c %f", &a, &op, &b);
    switch(op) 
    {
        case '+': printf("%f", a + b); break;
        case '-': printf("%f", a - b); break;
        case '*': printf("%f", a * b); break;
        case '/': printf("%f", a / b); break;
        case '%': printf("%f", a % b); break;
        default: printf("Invalid operator");
    }
    return 0;
}
